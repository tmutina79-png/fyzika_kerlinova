---
import MainLayout from '../layouts/MainLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';
---

<MainLayout title="Materiály">
  <div class="flex items-start justify-between gap-4 mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Vítej na Studijním portálu 🎓</h1>
    <div class="shrink-0 flex flex-col items-center" id="homepage-qr">
      <button id="qr-open-btn" class="rounded-xl border border-primary-200 bg-white p-2 shadow-sm hover:shadow-md hover:border-primary-400 transition-all cursor-pointer" aria-label="Zobrazit QR kód" title="Zobraz na mobilu">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=https%3A%2F%2Ftmutina79-png.github.io%2Ffyzika_kerlinova%2F" alt="QR kód portálu" style="width:105px;height:105px;" />
      </button>
      <span class="text-[10px] text-gray-400 mt-1">📱 Naskenuj a otevři na tabletu nebo mobilu</span>
    </div>
  </div>

  <!-- QR modal -->
  <div id="qr-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.6);justify-content:center;align-items:center;">
    <div style="background:#fff;border-radius:1rem;padding:2rem;text-align:center;max-width:420px;position:relative;">
      <button id="qr-close-btn" style="position:absolute;top:0.5rem;right:0.75rem;font-size:1.5rem;background:none;border:none;cursor:pointer;color:#666;">&times;</button>
      <h3 style="font-size:1.1rem;font-weight:700;margin-bottom:1rem;">📱 Naskenuj QR kód</h3>
      <img src="https://api.qrserver.com/v1/create-qr-code/?size=400x400&data=https%3A%2F%2Ftmutina79-png.github.io%2Ffyzika_kerlinova%2F" alt="QR kód portálu" style="width:300px;height:300px;margin:0 auto;" />
      <p style="color:#888;font-size:.85rem;margin-top:.75rem;">Namiř fotoaparát mobilu na QR kód</p>
    </div>
  </div>

  <script is:inline>
    document.getElementById('qr-open-btn')?.addEventListener('click', function() {
      var m = document.getElementById('qr-modal');
      if (m) { m.style.display = 'flex'; }
    });
    document.getElementById('qr-close-btn')?.addEventListener('click', function() {
      var m = document.getElementById('qr-modal');
      if (m) { m.style.display = 'none'; }
    });
    document.getElementById('qr-modal')?.addEventListener('click', function(e) {
      if (e.target === this) { this.style.display = 'none'; }
    });
  </script>

  <!-- Výukové materiály – sem doplň karty s odkazy na lekce -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-primary-700 mb-4">📚 Výukové materiály</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Hybnost -->
      <a href={`${base}docs/hybnost`}
         class="vm-card group block rounded-xl border border-primary-200 bg-white p-5 shadow-sm hover:shadow-lg hover:border-primary-400 transition-all"
         data-sidebar="details-hybnost">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">⚛️</span>
          <h3 class="text-base font-bold text-primary-800 group-hover:text-primary-600 transition-colors">Hybnost</h3>
        </div>
        <p class="text-sm text-gray-500 leading-relaxed">
          Hybnost, impuls síly, zákon zachování hybnosti – teorie, vizualizace, příklady a kvízy.
        </p>
        <div class="flex flex-wrap gap-1.5 mt-3">
          <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-primary-100 text-primary-700">Teorie</span>
          <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-green-100 text-green-700">Video</span>
          <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">Kvíz</span>
          <span class="inline-block text-[10px] px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">Příklady</span>
        </div>
      </a>

    </div>
  </section>

  <script is:inline>
    // Na homepage: sidebar logika
    (function() {
      const state = {};
      document.querySelectorAll('#sidebar details[id]').forEach(d => {
        state[d.id] = false;
      });
      sessionStorage.setItem('sidebar-details-state', JSON.stringify(state));
      document.querySelectorAll('#sidebar details[id]').forEach(d => {
        d.open = !!state[d.id];
      });
    })();

    // Po kliknutí na kartu VM: otevři odpovídající sekci v sidebaru
    document.querySelectorAll('.vm-card').forEach(card => {
      card.addEventListener('click', () => {
        const sidebarId = card.getAttribute('data-sidebar');
        if (!sidebarId) return;
        const state = {};
        document.querySelectorAll('#sidebar details[id]').forEach(d => {
          state[d.id] = false;
        });
        state[sidebarId] = true;
        sessionStorage.setItem('sidebar-details-state', JSON.stringify(state));
      });
    });
  </script>
</MainLayout>
